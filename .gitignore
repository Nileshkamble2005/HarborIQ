# ============================================================
# HarborIQ — .gitignore
# ============================================================

# ── Large raw data files managed via Git LFS ─────────────
# (tracked in .gitattributes — no longer excluded)

# ── Python cache & environment ────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.env
venv/
env/
.venv/
*.egg-info/
dist/
build/

# ── Jupyter Notebook checkpoints ─────────────────────────
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# ── OS generated files ────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE / Editor files ────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ── Logs & temp files ─────────────────────────────────────
*.log
*.tmp
*.bak
